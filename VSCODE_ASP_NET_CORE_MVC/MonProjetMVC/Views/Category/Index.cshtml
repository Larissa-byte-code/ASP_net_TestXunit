@model IEnumerable<MonProjetMVC.Models.TblCategory>
@{
    ViewData["Title"] = "Catégories";
    var editCategory = ViewBag.EditCategory as MonProjetMVC.Models.TblCategory;
}

<h2>Gestion des Catégories</h2>

@if (TempData["Debug"] != null)
{
    <div class="alert alert-danger">
        <strong>Erreurs :</strong> @TempData["Debug"]
    </div>
}

@if (editCategory != null)
{
    <h4 class="text-warning">Modifier la catégorie : @editCategory.CatName</h4>
    <form asp-controller="Category" asp-action="Edit" method="post" class="mb-4">

        <input type="hidden" name="CatId"   value="@editCategory.CatId" />
        <input type="hidden" name="CatIdvC" value="@editCategory.CatIdvC" />

        <div class="row mb-2">
            <div class="col-md-2">
                <label>ID</label>
                <input type="text" class="form-control"
                       value="@editCategory.CatId" readonly />
            </div>
            <div class="col-md-3">
                <label>Code formaté</label>
                <input type="text" class="form-control"
                       value="@editCategory.CatIdvC" readonly />
            </div>
            <div class="col-md-3">
                <label>Nom</label>
                <input type="text" name="CatName" class="form-control"
                       value="@editCategory.CatName" required />
            </div>
            <div class="col-md-4">
                <label>Description</label>
                <input type="text" name="CatDes" class="form-control"
                       value="@editCategory.CatDes" required />
            </div>
        </div>

        <button type="submit" class="btn btn-warning">
            Enregistrer modification
        </button>
        <a asp-controller="Category" asp-action="Index" class="btn btn-secondary">
            Annuler
        </a>

    </form>
}
else
{
    <h4 class="text-success">Ajouter une nouvelle catégorie</h4>
    <form asp-controller="Category" asp-action="Create" method="post" class="mb-4">

        <input type="hidden" name="CatId"   value="0" />
        <input type="hidden" name="CatIdvC" value="@ViewBag.NextCode" />

        <div class="row mb-2">
            <div class="col-md-2">
                <label>ID</label>
                <input type="text" class="form-control"
                       value="@ViewBag.NextId" readonly />
            </div>
            <div class="col-md-3">
                <label>Code formaté</label>
                <input type="text" class="form-control"
                       value="@ViewBag.NextCode" readonly />
            </div>
            <div class="col-md-3">
                <label>Nom</label>
                <input type="text" name="CatName" class="form-control"
                       placeholder="Nom de la catégorie" required />
            </div>
            <div class="col-md-4">
                <label>Description</label>
                <input type="text" name="CatDes" class="form-control"
                       placeholder="Description" required />
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Ajouter</button>
        <a asp-controller="Category" asp-action="New" class="btn btn-secondary">New</a>

    </form>
}

<hr />

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Code</th>
            <th>Nom</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CatId</td>
            <td>@item.CatIdvC</td>
            <td>@item.CatName</td>
            <td>@item.CatDes</td>
            <td>
                <a asp-controller="Category"
                   asp-action="Edit"
                   asp-route-id="@item.CatId"
                   class="btn btn-warning btn-sm">Edit</a>
                <a asp-controller="Category"
                   asp-action="Delete"
                   asp-route-id="@item.CatId"
                   class="btn btn-danger btn-sm"
                   onclick="return confirm('Supprimer cette catégorie ?')">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>