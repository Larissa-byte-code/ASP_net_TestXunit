@model IEnumerable<MonProjetMVC.Models.TblProduct>
@{
    ViewData["Title"] = "Produits";
    var editProduct = ViewBag.EditProduct as MonProjetMVC.Models.TblProduct;
}

<h2>Gestion des Produits</h2>

@if (TempData["Debug"] != null)
{
    <div class="alert alert-danger">
        <strong>Erreurs :</strong> @TempData["Debug"]
    </div>
}

@if (editProduct != null)
{
    <h4 class="text-warning">Modifier le produit : @editProduct.prdName</h4>
    <form asp-controller="Product" asp-action="Edit" method="post" class="mb-4">

        <input type="hidden" name="prdId"   value="@editProduct.prdId" />
        <input type="hidden" name="prdIdvC" value="@editProduct.prdIdvC" />

        <div class="row mb-2">
            <div class="col-md-2">
                <label>ID</label>
                <input type="text" class="form-control"
                       value="@editProduct.prdId" readonly />
            </div>
            <div class="col-md-3">
                <label>Code formaté</label>
                <input type="text" class="form-control"
                       value="@editProduct.prdIdvC" readonly />
            </div>
            <div class="col-md-3">
                <label>Nom</label>
                <input type="text" name="prdName" class="form-control"
                       value="@editProduct.prdName" required />
            </div>
            <div class="col-md-3">
                <label>Catégorie</label>
                <input type="text" name="prdCat" class="form-control"
                       value="@editProduct.prdCat" required />
            </div>
        </div>

        <button type="submit" class="btn btn-warning">
            Enregistrer modification
        </button>
        <a asp-controller="Product" asp-action="Index" class="btn btn-secondary">
            Annuler
        </a>

    </form>
}
else
{
    <h4 class="text-success">Ajouter un nouveau produit</h4>
    <form asp-controller="Product" asp-action="Create" method="post" class="mb-4">

        <input type="hidden" name="prdId"   value="0" />
        <input type="hidden" name="prdIdvC" value="@ViewBag.NextCode" />

        <div class="row mb-2">
            <div class="col-md-2">
                <label>ID</label>
                <input type="text" class="form-control"
                       value="@ViewBag.NextId" readonly />
            </div>
            <div class="col-md-3">
                <label>Code formaté</label>
                <input type="text" class="form-control"
                       value="@ViewBag.NextCode" readonly />
            </div>
            <div class="col-md-3">
                <label>Nom</label>
                <input type="text" name="prdName" class="form-control"
                       placeholder="Nom du produit" required />
            </div>
            <div class="col-md-3">
                <label>Catégorie</label>
                <input type="text" name="prdCat" class="form-control"
                       placeholder="Catégorie" required />
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Ajouter</button>
        <a asp-controller="Product" asp-action="New" class="btn btn-secondary">New</a>

    </form>
}

<hr />

<table class="table table-dark table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Code</th>
            <th>Nom</th>
            <th>Catégorie</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.prdId</td>
            <td>@item.prdIdvC</td>
            <td>@item.prdName</td>
            <td>@item.prdCat</td>
            <td>
                <a asp-controller="Product"
                   asp-action="Edit"
                   asp-route-id="@item.prdId"
                   class="btn btn-warning btn-sm">Edit</a>
                <a asp-controller="Product"
                   asp-action="Delete"
                   asp-route-id="@item.prdId"
                   class="btn btn-danger btn-sm"
                   onclick="return confirm('Supprimer ce produit ?')">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>